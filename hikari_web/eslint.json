."},{"messageId":"suggestNever","fix":{"range":[4393,4396],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { tool } from \"ai\"\r\nimport { z } from \"zod\"\r\nimport { createClient } from \"@/utils/supabase/server\"\r\n\r\n// Helper to get the authenticated users profile ID\r\nasync function getUserId() {\r\n    const supabase = await createClient()\r\n    const {\r\n        data: { user: authUser },\r\n    } = await supabase.auth.getUser()\r\n\r\n    if (!authUser) throw new Error(\"Unauthorized AI Tool Access: No authenticated user.\")\r\n\r\n    const { data: user } = await supabase\r\n        .from(\"users\")\r\n        .select(\"id\")\r\n        .eq(\"auth_id\", authUser.id)\r\n        .single()\r\n\r\n    if (!user) throw new Error(\"User profile not found in public database.\")\r\n\r\n    return { supabase, userId: user.id }\r\n}\r\n\r\nexport const buildVfsTools = () => {\r\n    return {\r\n        list_files: tool({\r\n            description: \"List all files in the Virtual File System, optionally filtering by directory.\",\r\n            inputSchema: z.object({\r\n                directory: z.string().optional().describe(\"E.g., 'main/' or 'daily-diary/'. If omitted, lists all files.\"),\r\n            }),\r\n            execute: async ({ directory }) => {\r\n                try {\r\n                    const { supabase, userId } = await getUserId()\r\n                    let query = supabase.from(\"virtual_files\").select(\"filepath, last_modified\").eq(\"user_id\", userId)\r\n\r\n                    if (directory) {\r\n                        query = query.like(\"filepath\", `${directory}%`)\r\n                    }\r\n\r\n                    const { data, error } = await query\r\n                    if (error) throw error\r\n                    return { success: true, files: data }\r\n                } catch (e: any) {\r\n                    return { success: false, error: e.message }\r\n                }\r\n            },\r\n        }),\r\n\r\n        read_file: tool({\r\n            description: \"Read the exact textual content of a specific file from the Virtual File System.\",\r\n            inputSchema: z.object({\r\n                filepath: z.string().describe(\"Exact path, e.g., 'main/identity-core.md'\"),\r\n            }),\r\n            execute: async ({ filepath }) => {\r\n                try {\r\n                    const { supabase, userId } = await getUserId()\r\n                    const { data, error } = await supabase\r\n                        .from(\"virtual_files\")\r\n                        .select(\"content, last_modified\")\r\n                        .eq(\"user_id\", userId)\r\n                        .eq(\"filepath\", filepath)\r\n                        .single()\r\n\r\n                    if (error) {\r\n                        if (error.code === \"PGRST116\") {\r\n                            return { success: false, message: `File '${filepath}' not found or is empty.` }\r\n                        }\r\n                        throw error\r\n                    }\r\n                    return { success: true, filepath, content: data.content, last_modified: data.last_modified }\r\n                } catch (e: any) {\r\n                    return { success: false, error: e.message }\r\n                }\r\n            },\r\n        }),\r\n\r\n        write_files: tool({\r\n            description: \"Atomically create or update one or multiple files in the Virtual File System.\",\r\n            inputSchema: z.object({\r\n                files: z.array(\r\n                    z.object({\r\n                        filepath: z.string().describe(\"Exact path, e.g., 'main/current-session.md'\"),\r\n                        content: z.string().describe(\"The full markdown content to save.\"),\r\n                    })\r\n                ).describe(\"An array of files to write atomically.\"),\r\n            }),\r\n            execute: async ({ files }) => {\r\n                try {\r\n                    const { supabase, userId } = await getUserId()\r\n\r\n                    const upsertPayload = files.map((f) => ({\r\n                        user_id: userId,\r\n                        filepath: f.filepath,\r\n                        content: f.content,\r\n                    }))\r\n\r\n                    // Supabase upsert handles array payloads atomically\r\n                    const { error } = await supabase\r\n                        .from(\"virtual_files\")\r\n                        .upsert(upsertPayload, { onConflict: \"user_id, filepath\" })\r\n\r\n                    if (error) throw error\r\n\r\n                    return { success: true, message: `Successfully saved ${files.length} file(s).` }\r\n                } catch (e: any) {\r\n                    return { success: false, error: e.message }\r\n                }\r\n            },\r\n        }),\r\n    }\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Git_Repo\\Project-AI-MemoryCore\\hikari_web\\app\\auth\\confirm\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Git_Repo\\Project-AI-MemoryCore\\hikari_web\\app\\layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Git_Repo\\Project-AI-MemoryCore\\hikari_web\\app\\login\\actions.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Git_Repo\\Project-AI-MemoryCore\\hikari_web\\app\\login\\page.tsx","me